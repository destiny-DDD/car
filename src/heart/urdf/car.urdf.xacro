<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="car">
    <xacro:include filename="base.urdf.xacro"/>
    <xacro:include filename="sensor/scan.urdf.xacro"/>
    <xacro:include filename="wheel/wheel.urdf.xacro"/>

